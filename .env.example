# Audio Processing Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Features ─────────────────────────────────────────────────────────────
# Required for: --post-correct, --name-speakers, --diarizer llm
OPENAI_API_KEY=sk-...

# ── PyAnnote Diarization ──────────────────────────────────────────────────────
# Required for: --diarizer pyannote
# Accept the model license at:
# https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_...

# ── Celery Distributed Workers ────────────────────────────────────────────────
# Only required when using tasks.py or docker-compose.yml
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_URL=redis://localhost:6379/1

# ── Watcher ───────────────────────────────────────────────────────────────────
# Default folders used by watcher.py (can also be passed as CLI flags)
INBOX_DIR=./inbox
OUTPUT_DIR=./output
PROCESSED_DIR=./processed
